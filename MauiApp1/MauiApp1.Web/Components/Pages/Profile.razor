@page "/profile"
@using MauiApp1.testowe
@inject MauiApp1.testowe.JobSearchService SearchService
@inject NavigationManager Nav

<div class="profile-container profile-cv">
    <section class="profile-hero">
        <div>
            <span class="profile-kicker">Profil dopasowania</span>
            <h2>Twoje CV i preferencje</h2>
            <p>Te dane są traktowane jak Twoje umiejętności, języki i warunki pracy. Na ich podstawie aplikacja filtruje wymagania oraz buduje wynik dopasowania ofert.</p>
        </div>
        <div class="profile-score-box">
            <strong>@ProfileCompletion%</strong>
            <span>uzupełnienia profilu</span>
        </div>
    </section>

    <div class="profile-grid">
        <details class="profile-panel profile-panel-wide profile-details" open>
            <summary>Dane podstawowe i kierunek pracy</summary>
            <div class="profile-form-grid">
                <label class="profile-field">
                    <span>Imię / nick</span>
                    <input type="text" @bind="SearchService.CurrentUser.Username" class="form-input" />
                </label>

                <label class="profile-field">
                    <span>Konto logowania</span>
                    <input type="text" value="@SearchService.CurrentUser.AccountLogin" class="form-input" disabled />
                </label>

                <label class="profile-field">
                    <span>Domyślna lokalizacja</span>
                    <select @bind="SearchService.CurrentUser.Settings.DefaultLocation" class="form-input">
                        @foreach (var city in LocationOptions)
                        {
                            <option value="@city">@city</option>
                        }
                    </select>
                </label>

                <label class="profile-field">
                    <span>Szukana rola / stanowisko</span>
                    <input type="text" @bind="SearchService.CurrentUser.Settings.JobTitle" class="form-input" placeholder="np. .NET Developer, sprzedawca, opiekun" />
                </label>

                <label class="profile-field">
                    <span>Kategoria zawodowa</span>
                    <select class="form-input"
                            value="@SearchService.CurrentUser.Settings.PreferredCategoryCode"
                            @onchange="HandleProfileCategoryChanged">
                        <option value="">Wybierz kategorię</option>
                        @foreach (var category in SearchService.CategoryOptions)
                        {
                            <option value="@category.CategoryCode">@category.CategoryName (@category.ActiveOfferCount)</option>
                        }
                    </select>
                </label>

                <label class="profile-field">
                    <span>Rola / stanowisko z bazy</span>
                    <select class="form-input"
                            value="@SearchService.CurrentUser.Settings.PreferredRoleCode"
                            @onchange="HandleProfileRoleChanged"
                            disabled="@(!HasProfileCategory)">
                        <option value="">Wybierz rolę</option>
                        @foreach (var role in SearchService.VisibleRoleOptions)
                        {
                            <option value="@role.RoleCode">@role.RoleName (@role.ActiveOfferCount)</option>
                        }
                    </select>
                </label>
            </div>
        </details>

        @if (!HasProfileScope)
        {
            <section class="profile-panel profile-panel-wide profile-empty-state">
                <h3>Najpierw wybierz kategorię i rolę</h3>
                <p>Po tym kroku pokażę tylko te sekcje profilu, które mają sens dla danego stanowiska. Dzięki temu nie trzeba przewijać technologii przy pracy w sprzedaży albo certyfikatów budowlanych przy IT.</p>
            </section>
        }
        else
        {
        <details class="profile-panel profile-details" open>
            <summary>Warunki pracy</summary>
            <div class="profile-form-grid one-col">
                <label class="profile-field">
                    <span>Minimalna stawka PLN/h</span>
                    <input type="number" min="0" step="1" @bind="SearchService.CurrentUser.Settings.ExpectedSalaryMin" class="form-input" />
                </label>

                <label class="profile-field">
                    <span>Tryb pracy</span>
                    <select @bind="SearchService.CurrentUser.Settings.WorkMode" class="form-input">
                        <option value="any">Dowolny</option>
                        <option value="remote">Zdalna</option>
                        <option value="hybrid">Hybrydowa</option>
                        <option value="onsite">Stacjonarna</option>
                        <option value="field">Terenowa</option>
                    </select>
                </label>

                <label class="profile-field">
                    <span>Wymiar pracy</span>
                    <select @bind="SearchService.CurrentUser.Settings.WorkTimeType" class="form-input">
                        <option value="any">Dowolny</option>
                        <option value="full_time">Pełny etat</option>
                        <option value="part_time">Część etatu</option>
                        <option value="flexible">Elastycznie</option>
                    </select>
                </label>

                <label class="profile-field">
                    <span>Maksymalny dystans dojazdu</span>
                    <input type="number" min="0" step="5" @bind="SearchService.CurrentUser.Settings.MaxDistanceKm" class="form-input" placeholder="np. 20" />
                </label>
            </div>
        </details>

        <details class="profile-panel profile-details">
            <summary>Doświadczenie i formalności</summary>
            <label class="profile-field">
                <span>Doświadczenie</span>
                <select @bind="SearchService.CurrentUser.Settings.Experience" class="form-input">
                    @foreach (var level in ExperienceOptions)
                    {
                        <option value="@level">@level</option>
                    }
                </select>
            </label>

            <label class="profile-field">
                <span>Wykształcenie</span>
                <select @bind="SearchService.CurrentUser.Settings.Education" class="form-input">
                    @foreach (var level in EducationOptions)
                    {
                        <option value="@level">@level</option>
                    }
                </select>
            </label>

            <div class="profile-chip-block">
                <span class="profile-label">Preferowane umowy</span>
                <div class="profile-pill-group">
                    @foreach (var type in ContractOptions)
                    {
                        <label class="profile-pill">
                            <input type="checkbox"
                                   checked="@IsSelected(SearchService.CurrentUser.Settings.PreferredContractTypes, type)"
                                   @onchange="@(e => ToggleList(SearchService.CurrentUser.Settings.PreferredContractTypes, type, e.Value is bool value && value))" />
                            @type
                        </label>
                    }
                </div>
            </div>
        </details>

        <details class="profile-panel profile-panel-wide profile-details">
            <summary>Języki z poziomami</summary>
            <div class="language-level-grid">
                @foreach (var language in LanguageOptions)
                {
                    <div class="language-level-row">
                        <label class="profile-pill language-pill">
                            <input type="checkbox"
                                   checked="@IsSelected(SearchService.CurrentUser.Settings.KnownLanguages, language)"
                                   @onchange="@(e => ToggleLanguage(language, e.Value is bool value && value))" />
                            @language
                        </label>
                        <select class="form-input"
                                value="@GetLanguageLevel(language)"
                                @onchange="@(e => SetLanguageLevel(language, e.Value?.ToString() ?? "unknown"))"
                                disabled="@(!IsSelected(SearchService.CurrentUser.Settings.KnownLanguages, language))">
                            @foreach (var level in LanguageLevels)
                            {
                                <option value="@level">@DisplayLanguageLevel(level)</option>
                            }
                        </select>
                    </div>
                }
            </div>
        </details>

        <details class="profile-panel profile-panel-wide profile-details" open>
            <summary>Umiejętności z bazy ofert</summary>
            <div class="profile-section-header">
                <div>
                    <p>Opcje są pobierane z aktualnych kryteriów importera. Zaznacz to, co realnie wpisujesz do CV.</p>
                </div>
                <label class="profile-threshold">
                    <span>Minimum wymaganych: @SearchService.CurrentUser.Settings.RequiredCriteriaMatchPercent%</span>
                    <input type="range" min="10" max="100" step="10" @bind="SearchService.CurrentUser.Settings.RequiredCriteriaMatchPercent" @bind:event="oninput" />
                </label>
            </div>

            @if (SkillOptions.Any())
            {
                @foreach (var group in SkillOptions.GroupBy(option => option.Kind).OrderBy(group => GetCriterionGroupOrder(group.Key)))
                {
                    <ProfileCriterionGroup Title="@SearchService.GetCriterionGroupLabel(group.Key)"
                                           Options="@group.OrderByDescending(option => option.ActiveOfferCount).ThenBy(option => option.DisplayName).Take(24).ToList()"
                                           SelectedCodes="@SearchService.CurrentUser.Settings.Skills"
                                           OnToggle="ToggleProfileCode" />
                }
            }
            else
            {
                <p class="profile-empty">Brak kryteriów z bazy. Uruchom import lub wybierz kategorię z ofertami.</p>
            }
        </details>

        @if (TraitOptions.Any() || ActivityOptions.Any() || CertificationOptions.Any())
        {
            <details class="profile-panel profile-panel-wide profile-details">
                <summary>Cechy, czynności i uprawnienia</summary>

                @if (TraitOptions.Any())
                {
                    <ProfileCriterionGroup Title="Cechy osobowe"
                                           Options="@TraitOptions"
                                           SelectedCodes="@SearchService.CurrentUser.Settings.PersonalTraits"
                                           OnToggle="ToggleProfileCode" />
                }

                @if (ActivityOptions.Any())
                {
                    <ProfileCriterionGroup Title="Rodzaj wykonywanej pracy"
                                           Options="@ActivityOptions"
                                           SelectedCodes="@SearchService.CurrentUser.Settings.WorkActivities"
                                           OnToggle="ToggleProfileCode" />
                }

                @if (CertificationOptions.Any())
                {
                    <ProfileCriterionGroup Title="Certyfikaty i uprawnienia"
                                           Options="@CertificationOptions"
                                           SelectedCodes="@SearchService.CurrentUser.Settings.Certifications"
                                           OnToggle="ToggleProfileCode" />
                }
            </details>
        }

        <details class="profile-panel profile-panel-wide profile-details">
            <summary>Czego nie chcesz</summary>
            <div class="profile-pill-group">
                @foreach (var flag in ExcludedFlagOptions)
                {
                    <label class="profile-pill">
                        <input type="checkbox"
                               checked="@IsSelected(SearchService.CurrentUser.Settings.ExcludedFlags, flag.Code)"
                               @onchange="@(e => ToggleList(SearchService.CurrentUser.Settings.ExcludedFlags, flag.Code, e.Value is bool value && value))" />
                        @flag.Label
                    </label>
                }
            </div>
        </details>
        }
    </div>

    <div class="profile-actions">
        <button class="btn-save" @onclick="SaveProfile">Zapisz profil</button>
        <button class="btn-search-profile" @onclick="SearchWithProfile">Szukaj według profilu</button>
    </div>

    @if (saved)
    {
        <p class="success">Profil zaktualizowany.</p>
    }
</div>

@code {
    private bool saved;

    protected override async Task OnInitializedAsync()
    {
        await SearchService.LoadSearchOptionsAsync();
        if (!string.IsNullOrWhiteSpace(SearchService.CurrentUser.Settings.PreferredCategoryCode))
        {
            await SearchService.SelectCategoryAsync(SearchService.CurrentUser.Settings.PreferredCategoryCode);
        }

        if (!string.IsNullOrWhiteSpace(SearchService.CurrentUser.Settings.PreferredRoleCode))
        {
            await SearchService.SelectRoleAsync(SearchService.CurrentUser.Settings.PreferredRoleCode);
        }
    }

    private List<string> LocationOptions = new()
    {
        "Rzeszów", "Kraków", "Warszawa", "Wrocław", "Gdańsk", "Poznań", "Łódź", "Katowice",
        "Lublin", "Szczecin", "Białystok", "Bydgoszcz", "Toruń", "Gdynia", "Częstochowa", "Wszystkie"
    };

    private List<string> ExperienceOptions = new()
    {
        "Wszystkie", "Brak doświadczenia", "Staż / praktyki", "Junior", "Mid / Regular",
        "Senior", "Lead / Principal", "Młodszy specjalista", "Specjalista", "Starszy specjalista", "Menadżer"
    };

    private List<string> EducationOptions = new()
    {
        "Brak wymagań lub niewymagane", "Student / w trakcie", "Średnie", "Wyższe"
    };

    private List<string> ContractOptions = new()
    {
        "Umowa o pracę", "Zlecenie", "B2B", "Pełny etat", "Część etatu"
    };

    private List<string> LanguageOptions = new()
    {
        "Angielski", "Niemiecki", "Ukraiński", "Francuski"
    };

    private List<string> LanguageLevels = new()
    {
        "unknown", "A1", "A2", "B1", "B2", "C1", "C2", "communicative", "fluent", "native"
    };

    private List<(string Code, string Label)> ExcludedFlagOptions = new()
    {
        ("night_shifts", "Bez nocek"),
        ("weekend_work", "Bez weekendów"),
        ("shift_work", "Bez pracy zmianowej"),
        ("delegations", "Bez delegacji"),
        ("physical_work", "Bez ciężkiej pracy fizycznej")
    };

    private static readonly HashSet<string> SkillKinds = new(StringComparer.OrdinalIgnoreCase)
    {
        "technology", "programming_language", "framework", "database", "cloud", "devops_tool",
        "testing_tool", "methodology", "data_tool", "ai_tool", "integration_tool", "business_tool",
        "industrial_tool"
    };

    private List<JobCriterionOption> SkillOptions => SearchService.CriteriaOptions
        .Where(option => SkillKinds.Contains(option.Kind))
        .ToList();

    private List<JobCriterionOption> TraitOptions => SearchService.CriteriaOptions
        .Where(option => option.Kind == "trait")
        .OrderByDescending(option => option.ActiveOfferCount)
        .ThenBy(option => option.DisplayName)
        .Take(24)
        .ToList();

    private List<JobCriterionOption> ActivityOptions => SearchService.CriteriaOptions
        .Where(option => option.Kind == "work_activity")
        .OrderByDescending(option => option.ActiveOfferCount)
        .ThenBy(option => option.DisplayName)
        .Take(24)
        .ToList();

    private List<JobCriterionOption> CertificationOptions => SearchService.CriteriaOptions
        .Where(option => option.Kind == "certification")
        .OrderByDescending(option => option.ActiveOfferCount)
        .ThenBy(option => option.DisplayName)
        .Take(24)
        .ToList();

    private bool HasProfileCategory => !string.IsNullOrWhiteSpace(SearchService.CurrentUser.Settings.PreferredCategoryCode);

    private bool HasProfileScope =>
        HasProfileCategory && !string.IsNullOrWhiteSpace(SearchService.CurrentUser.Settings.PreferredRoleCode);

    private int ProfileCompletion
    {
        get
        {
            var settings = SearchService.CurrentUser.Settings;
            var score = 0;
            if (!string.IsNullOrWhiteSpace(SearchService.CurrentUser.Username)) score += 10;
            if (!string.IsNullOrWhiteSpace(settings.JobTitle)) score += 10;
            if (settings.ExpectedSalaryMin > 0) score += 10;
            if (!string.Equals(settings.WorkMode, "any", StringComparison.OrdinalIgnoreCase)) score += 10;
            if (!string.Equals(settings.WorkTimeType, "any", StringComparison.OrdinalIgnoreCase)) score += 10;
            if (settings.GetProfileCriterionCodes().Any()) score += 25;
            if (settings.KnownLanguages.Any()) score += 15;
            if (settings.PreferredContractTypes.Any()) score += 10;
            return Math.Min(score, 100);
        }
    }

    private static int GetCriterionGroupOrder(string kind)
    {
        return kind switch
        {
            "programming_language" => 0,
            "framework" => 1,
            "database" => 2,
            "cloud" => 3,
            "devops_tool" => 4,
            "testing_tool" => 5,
            "data_tool" => 6,
            "ai_tool" => 7,
            "technology" => 8,
            _ => 20
        };
    }

    private async Task SaveProfile()
    {
        SearchService.SaveDataToDevice();
        saved = true;
        StateHasChanged();
        await Task.Delay(1800);
        saved = false;
        StateHasChanged();
    }

    private void SearchWithProfile()
    {
        SearchService.SaveDataToDevice();
        SearchService.ApplyProfileFilters();
        Nav.NavigateTo("/");
    }

    private async Task HandleProfileCategoryChanged(ChangeEventArgs e)
    {
        var categoryCode = e.Value?.ToString() ?? string.Empty;
        SearchService.CurrentUser.Settings.PreferredCategoryCode = categoryCode;
        SearchService.CurrentUser.Settings.PreferredRoleCode = string.Empty;
        await SearchService.SelectCategoryAsync(categoryCode);
    }

    private async Task HandleProfileRoleChanged(ChangeEventArgs e)
    {
        var roleCode = e.Value?.ToString() ?? string.Empty;
        SearchService.CurrentUser.Settings.PreferredRoleCode = roleCode;
        await SearchService.SelectRoleAsync(roleCode);
    }

    private static bool IsSelected(List<string> values, string code)
        => values.Contains(code, StringComparer.OrdinalIgnoreCase);

    private static void ToggleList(List<string> values, string code, bool isChecked)
    {
        if (string.IsNullOrWhiteSpace(code))
        {
            return;
        }

        if (isChecked)
        {
            if (!values.Contains(code, StringComparer.OrdinalIgnoreCase))
            {
                values.Add(code);
            }
        }
        else
        {
            values.RemoveAll(value => string.Equals(value, code, StringComparison.OrdinalIgnoreCase));
        }
    }

    private void ToggleProfileCode(ProfileCriterionToggle toggle)
    {
        ToggleList(toggle.SelectedCodes, toggle.Code, toggle.IsSelected);
    }

    private void ToggleLanguage(string language, bool isChecked)
    {
        ToggleList(SearchService.CurrentUser.Settings.KnownLanguages, language, isChecked);
        if (isChecked && !SearchService.CurrentUser.Settings.KnownLanguageLevels.ContainsKey(language))
        {
            SearchService.CurrentUser.Settings.KnownLanguageLevels[language] = "unknown";
        }

        if (!isChecked)
        {
            SearchService.CurrentUser.Settings.KnownLanguageLevels.Remove(language);
        }
    }

    private string GetLanguageLevel(string language)
    {
        return SearchService.CurrentUser.Settings.KnownLanguageLevels.TryGetValue(language, out var level)
            ? level
            : "unknown";
    }

    private void SetLanguageLevel(string language, string level)
    {
        if (!IsSelected(SearchService.CurrentUser.Settings.KnownLanguages, language))
        {
            return;
        }

        SearchService.CurrentUser.Settings.KnownLanguageLevels[language] = level;
    }

    private static string DisplayLanguageLevel(string level)
    {
        return level switch
        {
            "unknown" => "Poziom nieokreślony",
            "communicative" => "Komunikatywny",
            "fluent" => "Płynny",
            "native" => "Ojczysty",
            _ => level
        };
    }
}
