{
  "$schema": "https://dotnet.github.io/docfx/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "MauiApp1/MauiApp1.csproj",
            "MauiApp1.Importer/MauiApp1.Importer.csproj"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "index.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "JOB Search - dokumentacja kodu",
      "_appFooter": "Dokumentacja wygenerowana z komentarzy XML C#",
      "_enableSearch": true
    }
  }
}
